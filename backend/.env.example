# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=.secrets/service-account.json

# Gemini LLM
GEMINI_MODEL_NAME=gemini-2.0-flash

# Embedding
EMBEDDING_MODEL_NAME=text-embedding-004

# Firestore
FIRESTORE_COLLECTION_KNOWLEDGE=knowledge

# Auth
# Set AUTH_REQUIRED=false for local dev to skip Firebase JWT verification
AUTH_REQUIRED=true
# Comma-separated allowed CORS origins for production
# Example: CORS_ORIGINS=https://your-app.vercel.app,https://localhost:3000
CORS_ORIGINS=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
